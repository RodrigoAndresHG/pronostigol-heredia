{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/partido/:idPartido", "destination": "/api/meta?idPartido=:idPartido" },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/generar-predicciones",
      "schedule": "0 6 * * *"
    }
  ]
}
