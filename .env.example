# ──────────────────────────────────────────────────────────────────────
# PronostiGol HeredIA — Variables de entorno
#
# Copia este archivo a `.env.local` (NUNCA lo subas al repo) y completa
# las claves cuando vayas a usar cada integración. Mientras estén vacías,
# la app cae a datos mock para que puedas seguir construyendo UI.
# ──────────────────────────────────────────────────────────────────────

# ── IAs (Fase 3) ──────────────────────────────────────────────────────
# Las 3 claves viven SÓLO en el backend serverless (/api/*).
# Nunca prefijes con VITE_ — eso las expondría al navegador.

# Anthropic — modelo Claude (claude-sonnet-4-6 o más nuevo)
ANTHROPIC_API_KEY=

# OpenAI — modelo GPT (gpt-5 o el último disponible)
OPENAI_API_KEY=

# Google — modelo Gemini (gemini-2.5-flash o superior)
GOOGLE_API_KEY=


# ── Datos de fútbol (Fase 4) ──────────────────────────────────────────
# football-data.org · plan gratuito cubre Mundial. Registro: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# (Opcional) API-Football vía RapidAPI · respaldo y estadísticas extra.
RAPIDAPI_KEY=


# ── Cuotas de mercado (Fase 4) ────────────────────────────────────────
# The Odds API · 500 req/mes gratis. Registro: https://the-odds-api.com
ODDS_API_KEY=


# ── Supabase (Fase 5) ─────────────────────────────────────────────────
# La URL del proyecto va en el frontend (es pública) — sí lleva VITE_.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# La SERVICE ROLE KEY sólo se usa en /api (escrituras seguras) — sin VITE_.
SUPABASE_SERVICE_ROLE_KEY=
