# ──────────────────────────────────────────────────────────────────────
# PronostiGol HeredIA — Variables de entorno
#
# Copia este archivo a `.env.local` (NUNCA lo subas al repo) y completa
# las claves cuando vayas a usar cada integración. Mientras estén vacías,
# la app cae a datos mock para que puedas seguir construyendo UI.
# ──────────────────────────────────────────────────────────────────────

# ── IAs (Fase 3) ──────────────────────────────────────────────────────
# Las 3 claves viven SÓLO en el backend serverless (/api/*).
# Nunca prefijes con VITE_ — eso las expondría al navegador.

# Anthropic — clave de API (consíguela en https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
# Opcional · ID exacto del modelo de Claude. Si lo dejas vacío, default = claude-sonnet-4-5-20250929.
MODELO_CLAUDE=

# OpenAI — clave de API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Opcional · ID del modelo. Default = gpt-4o.
MODELO_GPT=

# Google — clave de API de Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Opcional · ID del modelo. Default = gemini-2.5-flash.
MODELO_GEMINI=


# ── Datos de fútbol (Fase 4) ──────────────────────────────────────────
# football-data.org · plan gratuito cubre Mundial. Registro: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# (Opcional) API-Football vía RapidAPI · respaldo y estadísticas extra.
RAPIDAPI_KEY=


# ── Cuotas de mercado (Fase 4) ────────────────────────────────────────
# The Odds API · 500 req/mes gratis. Registro: https://the-odds-api.com
ODDS_API_KEY=


# ── Supabase (Fase 3.5) ───────────────────────────────────────────────
# Las predicciones publicadas se guardan en la tabla `predicciones` de
# tu proyecto Supabase. Crea el proyecto y corre `supabase/schema.sql`
# en el SQL Editor antes de probar el flujo de generación.

# URL del proyecto (la encuentras en Project Settings → API).
VITE_SUPABASE_URL=
# anon / public key — sólo se usaría si el frontend leyera directo (no aún).
VITE_SUPABASE_ANON_KEY=
# service_role key — SECRETO. Permite escribir saltándose RLS. Sólo backend.
SUPABASE_SERVICE_ROLE_KEY=


# ── Código de admin (Fase 3.5) ────────────────────────────────────────
# String largo y aleatorio. Sólo TÚ lo conoces. Con él autorizas las
# llamadas POST /api/predecir que generan y publican una predicción.
# Genera uno con: openssl rand -hex 32
# Mínimo 16 caracteres — el backend rechaza claves más cortas.
CODIGO_ADMIN=
